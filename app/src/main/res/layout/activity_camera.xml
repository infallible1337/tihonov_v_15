<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A">


    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#2C2C2C" />


    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/camera_grid" />

    <!-- Иконка камеры в центре -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📷"
        android:textSize="64sp"
        android:layout_gravity="center"
        android:alpha="0.3" />

    <!-- Верхняя панель -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:paddingTop="24dp"
        android:gravity="center_vertical"
        android:background="@android:color/transparent">

        <Button
            android:id="@+id/btnClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/ic_close_white"
            android:backgroundTint="@android:color/transparent"
            android:elevation="4dp"
            android:contentDescription="Закрыть камеру" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />


        <Button
            android:id="@+id/btnFlip"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/ic_flip_camera"
            android:backgroundTint="@android:color/transparent"
            android:elevation="4dp"
            android:contentDescription="Перевернуть камеру" />
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:paddingBottom="40dp"
        android:background="@android:color/transparent">


        <Button
            android:id="@+id/btnCapture"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/ic_capture_button"
            android:backgroundTint="@android:color/transparent"
            android:elevation="4dp"
            android:contentDescription="Сделать снимок" />


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="СНИМОК"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:alpha="0.6" />
    </LinearLayout>

</FrameLayout>